<odoo>
    <!-- 1. Report Action -->
    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="name">Quotation / Order (Engineering)</field>
        <field name="report_name">engineering_packages.report_saleorder_custom_document</field>
        <field name="report_file">engineering_packages.report_saleorder_custom_document</field>
    </record>

    <!-- 2. The PDF Design -->
    <template id="report_saleorder_custom_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.basic_layout">
                    <!-- Added page-break-inside avoid to force one page -->
                    <div class="page o_report_layout_custom_engineering" style="direction: rtl; text-align: right; font-family: 'Tajawal', sans-serif; font-size: 14px; page-break-inside: avoid;">
                        
                        <!-- HEADER WITH LOGO -->
                        <div class="row" style="border-bottom: 2px solid #2c3e50; padding-bottom: 10px; margin-bottom: 15px;">
                            <div class="col-4">
                                <!-- تم تصغير اللوجو قليلاً لضمان بقاء المحتوى في صفحة واحدة -->
                                <img t-if="doc.company_id.logo" t-att-src="image_data_uri(doc.company_id.logo)" style="max-height: 110px; max-width: 100%; object-fit: contain;" alt="Logo"/>
                            </div>
                            <div class="col-8 text-left" style="padding-top: 15px;">
                                <h2 style="margin:0; padding:0; font-weight: bold; color: #2c3e50;">ديناميك للإستشارات الهندسية</h2>
                                <h4 style="margin:0; padding:0; color: #7f8c8d; font-weight: bold;">DYNAMIC ENGINEERING CONSULTANTS</h4>
                            </div>
                        </div>

                        <!-- BLACK TITLE BAR -->
                        <div style="background-color: #2c3e50; color: #fff; text-align: center; padding: 6px; font-size: 13px; margin-bottom: 15px; border-radius: 4px; font-weight: bold;">
                            إستشاريون (تصميم وإشراف) - معماري - إنشائي - مباني وإنشاءات - تصميم - إدارة مشاريع
                        </div>

                        <!-- MAIN TITLE & DATE -->
                        <div class="row" style="margin-bottom: 15px;">
                            <div class="col-6 text-right">
                                <strong>تاريخ: </strong> <span t-field="doc.date_order" t-options='{"widget": "date"}'/>
                            </div>
                            <div class="col-6 text-left">
                                <strong>رقم العرض: </strong> <span t-field="doc.name"/>
                            </div>
                        </div>
                        
                        <div style="text-align: center; margin-bottom: 15px;">
                            <h3 style="text-decoration: underline; font-weight: bold; color: #2c3e50; margin: 0;">عرض سعر خدمات إستشارية</h3>
                        </div>

                        <!-- SUBJECT & CUSTOMER -->
                        <div style="margin-bottom: 15px; line-height: 1.6;">
                            <strong>السادة / </strong> <span t-field="doc.partner_id.name"/> المحترمين،<br/>
                            تحية طيبة وبعد،،،<br/>
                            <strong>الموضوع: </strong> عرض سعر تصميم وترخيص وإشراف مبنى <span t-if="doc.building_type" t-field="doc.building_type"/>
                        </div>

                        <!-- 1. SERVICES AND PROJECT DETAILS -->
                        <div style="margin-bottom: 15px; border: 1px solid #bdc3c7; border-radius: 6px; padding: 15px; background-color: #f8f9fa;">
                            <h5 style="color: #2980b9; margin-top: 0; margin-bottom: 10px; font-weight: bold; border-bottom: 1px solid #ecf0f1; padding-bottom: 5px;">
                                تفاصيل الخدمة والمشروع (Project Details)
                            </h5>
                            <table style="width: 100%; font-size: 14px;">
                                <tr>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>نوع الخدمة:</strong> <span t-if="doc.service_type" t-field="doc.service_type"/>
                                    </td>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>المساحة:</strong> <span t-if="doc.area" t-field="doc.area"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>المحافظة:</strong> <span t-if="doc.governorate_id" t-esc="doc.governorate_id.name.replace('محافظة', '').replace('محافظه', '').strip()"/>
                                    </td>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>المنطقة:</strong> <span t-if="doc.region_id" t-field="doc.region_id.name"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>القطعة:</strong> <span t-if="doc.block_no" t-field="doc.block_no"/>
                                    </td>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>الشارع:</strong> <span t-if="doc.street_no" t-field="doc.street_no"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="width: 50%; padding: 4px 0;">
                                        <strong>رقم القسيمة:</strong> <span t-if="doc.plot_no" t-field="doc.plot_no"/>
                                    </td>
                                    <td style="width: 50%; padding: 4px 0;">
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- 2. PACKAGE PRICE -->
                        <t t-if="doc.engineering_package_id and doc.engineering_package_id.list_price">
                            <div style="margin-bottom: 15px; padding: 12px; background-color: #e3f2fd; border: 1px solid #90caf9; border-radius: 6px; text-align: center;">
                                <h4 style="margin: 0; color: #1565c0; font-weight: bold;">
                                    إجمالي سعر الباقة: <span t-field="doc.engineering_package_id.list_price"/>
                                </h4>
                            </div>
                        </t>

                        <!-- 3. REQUIRED DOCUMENTS (Changed to Blue Style) -->
                        <t t-if="doc.required_documents">
                            <div style="margin-bottom: 20px; padding: 15px; border: 1px solid #b3d4fc; background-color: #eaf4ff; border-radius: 6px;">
                                <h5 style="color: #0056b3; margin-top: 0; margin-bottom: 10px; font-weight: bold;">
                                    في حالة الموافقة على عرض السعر، يرجى إرسال هذه المستندات إلينا على الرقم: 22091228
                                </h5>
                                <div style="font-size: 14px; line-height: 1.6; color: #333;">
                                    <span t-field="doc.required_documents"/>
                                </div>
                            </div>
                        </t>

                        <!-- SIGNATURE -->
                        <div style="margin-top: 20px; font-size: 14px; text-align: left;">
                            مع خالص التحية والتقدير،،،
                            <br/><br/><br/>
                            <strong style="color: #2c3e50; font-size: 16px;">ديناميك ديزاين للإستشارات الهندسية</strong>
                        </div>
                        
                        <!-- FOOTER -->
                        <div class="footer" style="border-top: 2px solid #2c3e50; text-align: center; font-size: 11px; padding-top: 8px; margin-top: 15px; color: #555;">
                            مدينة الكويت - قبلة - شارع الصالحية - مبنى رقم (18) الدور الأول مكتب رقم (1)
                            <br/>
                            E-mail: info@DynamicSaud.com | Mobile: 99674300 - 50855599
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>