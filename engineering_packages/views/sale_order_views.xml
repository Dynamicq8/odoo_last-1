<odoo>
    <record id="view_order_form_inherit_engineering_package" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.engineering.package</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <!-- 
                    The 'building_type' field is required in this view 
                    because it's used in the domain of 'engineering_package_id'.
                    We make it invisible to avoid showing it twice if it's already
                    displayed by 'engineering_core'.
                -->
                <field name="building_type" invisible="1"/>
                
                <field name="engineering_package_id" 
                       options="{'no_create': True, 'no_open': True}"
                       placeholder="اختر باقة هندسية..."/>
            </xpath>
        </field>
    </record>
</odoo>
