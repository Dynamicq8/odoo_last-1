<odoo>
    <template id="sale_order_portal_content_inherit_package_features" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//table[@id='sales_order_table']" position="before">
            
            <!-- Check if the field has any value -->
            <t t-if="sale_order.package_features_html">
                <div class="card mt-4 mb-4 border-primary">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">مميزات الباقة (Package Features)</h4>
                    </div>
                    <div class="card-body">
                        <!-- Use t-out for HTML fields to ensure tags render -->
                        <div t-out="sale_order.package_features_html"/>
                    </div>
                </div>
            </t>

        </xpath>
    </template>
</odoo>
