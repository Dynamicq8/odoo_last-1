<odoo>
    <template id="sale_order_portal_content_inherit_engineering" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//div[@id='informations']" position="after">
            
            <div class="row mt-4 mb-4" id="engineering_details">
                <div class="col-12">
                    <h5 class="mb-3 text-primary">تفاصيل المشروع (Project Details)</h5>
                    <hr/>
                </div>

                <!-- Column 1: Type -->
                <div class="col-lg-6 col-md-6 col-sm-12">
                    <div class="mb-2" t-if="sale_order.building_type">
                        <strong>نوع العقار (Building Type):</strong>
                        <span t-field="sale_order.building_type"/>
                    </div>
                    <div class="mb-2" t-if="sale_order.service_type">
                        <strong>نوع الخدمة (Service Type):</strong>
                        <span t-field="sale_order.service_type"/>
                    </div>

                    <!-- NEW LINE: Total Services Price -->
                    <div class="mb-2" t-if="sale_order.amount_untaxed">
                        <strong>سعر جميع الخدمات:</strong>
                        <span t-field="sale_order.amount_untaxed"/>
                    </div>

                    <!-- NEW LINE: Package Price -->
                    <div class="mb-2" t-if="sale_order.engineering_package_id and sale_order.engineering_package_id.list_price">
                        <strong>سعر الباقة:</strong>
                        <span t-field="sale_order.engineering_package_id.list_price"/>
                    </div>

                     <div class="mb-2" t-if="sale_order.area">
                        <strong>المساحة (Area):</strong>
                        <span t-field="sale_order.area"/>
                    </div>
                </div>

                <!-- Column 2: Location -->
                <div class="col-lg-6 col-md-6 col-sm-12">
                    <div class="mb-2" t-if="sale_order.governorate_id">
                        <strong>المحافظة (Governorate):</strong>
                        <span t-esc="sale_order.governorate_id.name.replace('محافظة', '').replace('محافظه', '').strip()"/>
                    </div>
                    <div class="mb-2" t-if="sale_order.region_id">
                        <strong>المنطقة (Region):</strong>
                        <span t-field="sale_order.region_id.name"/>
                    </div>
                    <div class="mb-2" t-if="sale_order.block_no">
                        <strong>القطعة (Block):</strong>
                        <span t-field="sale_order.block_no"/>
                    </div>
                    <div class="mb-2" t-if="sale_order.street_no">
                        <strong>الشارع (Street):</strong>
                        <span t-field="sale_order.street_no"/>
                    </div>
                    <div class="mb-2" t-if="sale_order.plot_no">
                        <strong>رقم القسيمة (Plot):</strong>
                        <span t-field="sale_order.plot_no"/>
                    </div>
                </div>
            </div>

            <!-- PACKAGE FEATURES OR DESCRIPTION BLOCK -->
            <t t-if="sale_order.engineering_package_id">
                
                <!-- 1. Check if Features exist on the Package -->
                <t t-if="sale_order.engineering_package_id.feature_ids">
                    <div class="row mt-4 mb-4" id="package_features_section">
                        <div class="col-12">
                            <h5 class="mb-3 text-primary">مميزات الباقة (Package Features)</h5>
                            <hr/>
                            <ul class="list-group" style="max-width: 600px;">
                                <t t-foreach="sale_order.engineering_package_id.feature_ids" t-as="feature">
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span t-out="feature.name"/>
                                        <i t-if="feature.included" class="fa fa-check text-success"/>
                                        <i t-if="not feature.included" class="fa fa-times text-danger"/>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </t>
                
                <!-- 2. If Features are empty, check if Description exists -->
                <t t-elif="sale_order.engineering_package_id.description and sale_order.engineering_package_id.description != '&lt;p&gt;&lt;br&gt;&lt;/p&gt;'">
                    <div class="row mt-4 mb-4" id="package_description_section">
                        <div class="col-12">
                            <h5 class="mb-3 text-primary">تفاصيل الباقة (Package Details)</h5>
                            <hr/>
                            <div t-field="sale_order.engineering_package_id.description"/>
                        </div>
                    </div>
                </t>

            </t>
            <!-- END PACKAGE BLOCK -->

            <!-- REQUIRED DOCUMENTS BLOCK (NEW) -->
            <t t-if="sale_order.required_documents">
                <div class="row mt-4 mb-4" id="required_documents_section">
                    <div class="col-12">
<h5 class="mb-3 text-danger">
في حالة الموافقة على عرض السعر، يرجى إرسال هذه المستندات إلينا على الرقم التالي: 22091228
</h5>                        <hr/>
                        <div class="bg-light p-3 rounded border">
                            <span t-field="sale_order.required_documents"/>
                        </div>
                    </div>
                </div>
            </t>
            <!-- END REQUIRED DOCUMENTS BLOCK -->

        </xpath>
    </template>
</odoo>