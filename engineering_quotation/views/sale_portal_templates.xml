<odoo>
    <template id="sale_order_portal_content_inherit_engineering" inherit_id="sale.sale_order_portal_content">
        <xpath expr="//div[@id='informations']" position="after">
            
            <div class="mt-4 mb-4" id="engineering_details_enhanced">
                
                <!-- 1. PROJECT DETAILS SECTION -->
                <div class="card shadow-sm border-0 mb-4 rounded">
                    <div class="card-header bg-white pt-4 pb-2 border-bottom-0">
                        <h5 class="mb-0 text-primary font-weight-bold">
                            <i class="fa fa-building" style="margin-left: 8px;"></i>تفاصيل المشروع (Project Details)
                        </h5>
                        <hr class="mt-3 mb-0 text-muted"/>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- Column 1: Type & Service -->
                            <div class="col-lg-6 col-md-6 col-sm-12 mb-3">
                                <div class="p-3 bg-light rounded h-100 border border-light">
                                    <div class="mb-3" t-if="sale_order.building_type">
                                        <span class="text-muted d-block mb-1" style="font-size: 0.85em;"><i class="fa fa-home" style="margin-left: 5px;"></i>نوع العقار (Building Type)</span>
                                        <strong style="font-size: 1.1em;"><span t-field="sale_order.building_type"/></strong>
                                    </div>
                                    <div class="mb-3" t-if="sale_order.service_type">
                                        <span class="text-muted d-block mb-1" style="font-size: 0.85em;"><i class="fa fa-cogs" style="margin-left: 5px;"></i>نوع الخدمة (Service Type)</span>
                                        <strong style="font-size: 1.1em;"><span t-field="sale_order.service_type"/></strong>
                                    </div>
                                    <div class="mb-1" t-if="sale_order.area">
                                        <span class="text-muted d-block mb-1" style="font-size: 0.85em;"><i class="fa fa-expand" style="margin-left: 5px;"></i>المساحة (Area)</span>
                                        <strong style="font-size: 1.1em;"><span t-field="sale_order.area"/></strong>
                                    </div>
                                </div>
                            </div>

                            <!-- Column 2: Location -->
                            <div class="col-lg-6 col-md-6 col-sm-12 mb-3">
                                <div class="p-3 bg-light rounded h-100 border border-light">
                                    <div class="mb-3" t-if="sale_order.governorate_id">
                                        <span class="text-muted d-block mb-1" style="font-size: 0.85em;"><i class="fa fa-map-marker" style="margin-left: 5px;"></i>المحافظة (Governorate)</span>
                                        <strong style="font-size: 1.1em;"><span t-esc="sale_order.governorate_id.name.replace('محافظة', '').replace('محافظه', '').strip()"/></strong>
                                    </div>
                                    <div class="mb-3" t-if="sale_order.region_id">
                                        <span class="text-muted d-block mb-1" style="font-size: 0.85em;"><i class="fa fa-map" style="margin-left: 5px;"></i>المنطقة (Region)</span>
                                        <strong style="font-size: 1.1em;"><span t-field="sale_order.region_id.name"/></strong>
                                    </div>
                                    
                                    <div class="row text-center mt-3 pt-3 border-top">
                                        <div class="col-4" t-if="sale_order.block_no">
                                            <span class="text-muted d-block mb-1" style="font-size: 0.85em;">القطعة</span>
                                            <strong><span t-field="sale_order.block_no"/></strong>
                                        </div>
                                        <div class="col-4" t-if="sale_order.street_no">
                                            <span class="text-muted d-block mb-1" style="font-size: 0.85em;">الشارع</span>
                                            <strong><span t-field="sale_order.street_no"/></strong>
                                        </div>
                                        <div class="col-4" t-if="sale_order.plot_no">
                                            <span class="text-muted d-block mb-1" style="font-size: 0.85em;">القسيمة</span>
                                            <strong><span t-field="sale_order.plot_no"/></strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. PACKAGE PRICE SECTION -->
                <div class="alert alert-primary shadow-sm mb-4 border-0 d-flex justify-content-between align-items-center rounded" t-if="sale_order.engineering_package_id and sale_order.engineering_package_id.list_price">
                    <div>
                        <h5 class="mb-0 font-weight-bold text-primary">
                            <i class="fa fa-tags" style="margin-left: 8px;"></i>سعر الباقة (Package Price)
                        </h5>
                    </div>
                    <div>
                        <h4 class="mb-0 font-weight-bold text-primary">
                            <span t-field="sale_order.engineering_package_id.list_price"/>
                        </h4>
                    </div>
                </div>

                <!-- 3. REQUIRED DOCUMENTS SECTION -->
                <t t-if="sale_order.required_documents">
                    <div class="card shadow-sm border-0 mb-4 rounded" id="required_documents_section">
                        <div class="card-header bg-white pt-4 pb-2 border-bottom-0">
                            <h5 class="mb-0 text-info font-weight-bold">
                                <i class="fa fa-folder-open" style="margin-left: 8px;"></i>المستندات المطلوبة (Required Documents)
                            </h5>
                            <hr class="mt-3 mb-0 text-muted"/>
                        </div>
                        <div class="card-body">
                            <!-- Changed from Red to Blue Info Alert -->
                            <div class="alert alert-info d-flex align-items-center shadow-sm mb-4 border-0">
                                <i class="fa fa-info-circle fa-2x" style="margin-left: 15px;"></i>
                                <div style="font-size: 1.05em; line-height: 1.6;">
                                    في حالة الموافقة على عرض السعر، يرجى إرسال هذه المستندات إلينا على الرقم التالي: <strong style="font-size: 1.2em;">22091228</strong>
                                </div>
                            </div>
                            <div class="p-4 bg-light rounded border border-light shadow-sm text-dark" style="font-size: 1.05em; line-height: 1.8;">
                                <span t-field="sale_order.required_documents"/>
                            </div>
                        </div>
                    </div>
                </t>

            </div>

        </xpath>
    </template>
</odoo>