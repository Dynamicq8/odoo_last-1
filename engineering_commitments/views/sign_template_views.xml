<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sign_template_view_form_inherit_engineering" model="ir.ui.view">
        <field name="name">sign.template.form.inherit.engineering</field>
        <field name="model">sign.template</field>
        <field name="inherit_id" ref="sign.sign_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <!-- Changed group title to fit both types -->
                <group string="Template Document Settings (إعدادات نوع المستند)">
                    <group>
                        <!-- Added the new selection fields -->
                        <field name="document_type" widget="radio"/> 
                        <field name="building_type"/>
                        <field name="service_type"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>