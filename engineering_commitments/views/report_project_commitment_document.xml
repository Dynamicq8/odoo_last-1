<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_project_commitment_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Minimal content to ensure loading -->
                        <h1>Commitment for <span t-field="doc.project_id.name"/></h1>
                        <p>This is a test report document.</p>
                        <!-- Remove complex t-fields and loops for now -->
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
