<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    =================================================
    1. Add Fields to SIGN TEMPLATE Form View
    =================================================
    -->
    <record id="sign_template_view_form_inherit_engineering" model="ir.ui.view">
        <field name="name">sign.template.form.inherit.engineering</field>
        <field name="model">sign.template</field>
        <field name="inherit_id" ref="sign.sign_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Engineering Commitment Settings (إعدادات التعهد الهندسي)">
                    <group>
                        <field name="is_commitment"/>
                        <field name="building_type"/>
                        <field name="service_type"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!--
    =================================================
    2. Add "Commitments" Tab to the TASK Form View
    =================================================

    Visibility rules for التعهدات tab on tasks:
    • Shown only for paperwork tasks (secretary / accountant role)
    • HIDDEN for:
        - العقد وتحصيل الدفعة الأولى
          codes: rn_1_3 | nrn_1_3 | ra_1_5 | nra_1_5 | dem_1_2
        - سيستم الأعمدة
          codes: rn_2_1 | nrn_2_1 | ra_2_1 | nra_2_1
    -->
    <record id="project_task_view_form_inherit_commitments" model="ir.ui.view">
        <field name="name">project.task.form.inherit.commitments</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <!--
                    التعهدات tab:
                    • Visible when: is_paperwork_task = True
                      AND workflow_step is NOT one of the excluded codes
                    • "site visit report" tab never existed in this view and is not added
                -->
                <page string="Commitments (تعهدات)"
      name="engineering_commitments"
      invisible="
          not is_paperwork_task
          or workflow_step not in [
              'rn_1_4',
              'nrn_1_4',
              'ra_3_1',
              'nra_1_4',
              'dem_1_3'
          ]
      ">

                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('is_commitment', '=', True)]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

    <!--
    ====================================================
    3. Add "Commitments" Tab to the main PROJECT Form View
    ====================================================
    No task-level filtering needed here — project-level commitments
    always show regardless of task type.
    -->
    <record id="project_project_view_form_inherit_commitments" model="ir.ui.view">
        <field name="name">project.project.form.inherit.commitments</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page string="Commitments (تعهدات)" name="engineering_commitments">

                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('is_commitment', '=', True)]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

</odoo>