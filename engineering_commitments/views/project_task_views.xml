<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    =================================================
    1. Update Fields in SIGN TEMPLATE Form View
    =================================================
    -->
    <record id="sign_template_view_form_inherit_engineering" model="ir.ui.view">
        <field name="name">sign.template.form.inherit.engineering</field>
        <field name="model">sign.template</field>
        <field name="inherit_id" ref="sign.sign_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Document Settings (إعدادات المستند)">
                    <group>
                        <field name="document_type"/>
                        <field name="package_id"/>
                        <field name="building_type"/>
                        <field name="service_type"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!--
    =================================================
    2. Add Tabs & Buttons to the TASK Form View
    =================================================
    -->
    <record id="project_task_view_form_inherit_documents" model="ir.ui.view">
        <field name="name">project.task.form.inherit.documents</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <!-- ======================================================== -->
            <!-- NEW: ADD BUTTON TO SUBTASKS LIST (Beside View & Delete)  -->
            <!-- ======================================================== -->
            <xpath expr="//field[@name='child_ids']/tree" position="inside">
                <!-- Ensure state is loaded in the tree so the condition works -->
                <field name="state" invisible="1"/>
                
                <!-- Quick Sign Button -->
                <button name="action_quick_sign_phase" 
                        type="object" 
                        string="إثبات المرحلة" 
                        class="btn-success" 
                        icon="fa-pencil-square-o"
                        invisible="state != '03_approved'"/>
            </xpath>


            <xpath expr="//notebook" position="inside">
                <!-- COMMITMENTS tab -->
                <page string="Commitments (تعهدات)"
                      name="engineering_commitments"
                      invisible="
                          not is_paperwork_task
                          or workflow_step not in [
                              'rn_1_4',
                              'nrn_1_4',
                              'ra_3_1',
                              'nra_1_4',
                              'dem_1_3'
                          ]
                      ">

                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'commitment')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

                <!-- COMPANY CONTRACTS tab -->
                <page string="Company Contracts (عقود الشركة)"
                      name="engineering_company_contracts"
                      invisible="
                          not is_paperwork_task
                          or workflow_step not in [
                              'rn_1_4',
                              'nrn_1_4',
                              'ra_3_1',
                              'nra_1_4',
                              'dem_1_3'
                          ]
                      ">

                    <div class="mb-3">
                        <button name="action_load_company_contracts"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_company_contracts_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="company_contract_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'company_contract')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

                <!-- PHASES APPROVALS tab (Subtasks & Supervision) -->
                <page string="Phases Approvals (اعتماد المراحل)"
                      name="engineering_phases_approvals"
                      invisible="not parent_id"> <!-- Visible ONLY on Subtasks -->

                    <!-- Ensure state field is loaded in view so invisible conditions work properly -->
                    <field name="state" invisible="1"/>

                    <!-- Warning shown when Subtask is NOT approved yet -->
                    <div class="alert alert-info" role="alert" invisible="state == '03_approved'">
                        <i class="fa fa-info-circle"/> يجب الموافقة على هذه المرحلة (Approved) أولاً لتتمكن من إثبات واعتماد المستندات.
                    </div>

                    <!-- Document loading shown ONLY when Subtask IS approved -->
                    <div class="mb-3" invisible="state != '03_approved'">
                        <button name="action_load_phases_approvals"
                                type="object"
                                string="Load Phase Template"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_phases_approvals_pdf"
                                type="object"
                                string="Generate PDF"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <!-- The Sign Form shown ONLY when Subtask IS approved -->
                    <field name="phase_approval_ids" invisible="state != '03_approved'">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'phases_approval')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <!-- Renamed to إثبات -->
                            <button name="action_sign_now"
                                    type="object"
                                    string="إثبات (Sign Now)"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

            </xpath>

        </field>
    </record>

    <!--
    ====================================================
    3. Add Tabs to the main PROJECT Form View
    ====================================================
    -->
    <record id="project_project_view_form_inherit_documents" model="ir.ui.view">
        <field name="name">project.project.form.inherit.documents</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <!-- COMMITMENTS tab -->
                <page string="Commitments (تعهدات)" name="engineering_commitments">
                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'commitment')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

                <!-- COMPANY CONTRACTS tab -->
                <page string="Company Contracts (عقود الشركة)" name="engineering_company_contracts">
                    <div class="mb-3">
                        <button name="action_load_company_contracts"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_company_contracts_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="company_contract_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'company_contract')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

                <!-- PHASES APPROVALS tab (Project Level) -->
                <page string="Phases Approvals (اعتماد المراحل)" name="engineering_phases_approvals">
                    <div class="mb-3">
                        <button name="action_load_phases_approvals"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_phases_approvals_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="phase_approval_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'phases_approval')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="إثبات (Sign Now)"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>