<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    =================================================
    1. Update Fields in SIGN TEMPLATE Form View
    =================================================
    -->
    <record id="sign_template_view_form_inherit_engineering" model="ir.ui.view">
        <field name="name">sign.template.form.inherit.engineering</field>
        <field name="model">sign.template</field>
        <field name="inherit_id" ref="sign.sign_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Document Settings (إعدادات المستند)">
                    <group>
                        <field name="document_type"/>
                        <field name="package_id"/>
                        <field name="building_type"/>
                        <field name="service_type"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!--
    =================================================
    2. Add "Commitments" and "Company Contracts" Tabs to the TASK Form View
    =================================================

    Visibility rules for التعهدات tab on tasks:
    • Shown only for paperwork tasks (secretary / accountant role)
    • HIDDEN for:
        - العقد وتحصيل الدفعة الأولى
          codes: rn_1_3 | nrn_1_3 | ra_1_5 | nra_1_5 | dem_1_2
        - سيستم الأعمدة
          codes: rn_2_1 | nrn_2_1 | ra_2_1 | nra_2_1
    -->
    <record id="project_task_view_form_inherit_documents" model="ir.ui.view">
        <field name="name">project.task.form.inherit.documents</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">

                <!-- COMMITMENTS tab -->
                <page string="Commitments (تعهدات)"
                      name="engineering_commitments"
                      invisible="
                          not is_paperwork_task
                          or workflow_step not in [
                              'rn_1_4',
                              'nrn_1_4',
                              'ra_3_1',
                              'nra_1_4',
                              'dem_1_3'
                          ]
                      ">

                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'commitment')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

                <!-- COMPANY CONTRACTS tab -->
                <page string="Company Contracts (عقود الشركة)"
                      name="engineering_company_contracts"
                      invisible="
                          not is_paperwork_task
                          or workflow_step not in [
                              'rn_1_4',
                              'nrn_1_4',
                              'ra_3_1',
                              'nra_1_4',
                              'dem_1_3'
                          ]
                      ">

                    <div class="mb-3">
                        <button name="action_load_company_contracts"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_company_contracts_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="company_contract_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'company_contract')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

            </xpath>

        </field>
    </record>

    <!--
    ====================================================
    3. Add "Commitments" and "Company Contracts" Tabs to the main PROJECT Form View
    ====================================================
    No task-level filtering needed here — project-level documents
    always show regardless of task type.
    -->
    <record id="project_project_view_form_inherit_documents" model="ir.ui.view">
        <field name="name">project.project.form.inherit.documents</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <!-- COMMITMENTS tab -->
                <page string="Commitments (تعهدات)" name="engineering_commitments">
                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'commitment')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>

                <!-- COMPANY CONTRACTS tab -->
                <page string="Company Contracts (عقود الشركة)" name="engineering_company_contracts">
                    <div class="mb-3">
                        <button name="action_load_company_contracts"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_company_contracts_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <field name="company_contract_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('document_type', '=', 'company_contract')]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>