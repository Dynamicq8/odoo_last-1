<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_view_form_inherit_commitments" model="ir.ui.view">
        <field name="name">project.task.form.inherit.commitments</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <!-- Insert a new page inside the notebook at the bottom of the task -->
            <xpath expr="//notebook" position="inside">
                <page string="Commitments (تعهدات)" name="engineering_commitments">
                    
                    <!-- The Action Buttons -->
                    <div class="mb-3">
                        <button name="action_load_commitments" 
                                type="object" 
                                string="Load Templates (تحميل القوالب)" 
                                class="btn-primary" 
                                icon="fa-download"/>
                                
                        <button name="action_generate_commitments_pdf" 
                                type="object" 
                                string="Generate PDFs (إنشاء المستندات)" 
                                class="btn-success ms-2" 
                                icon="fa-file-pdf-o"/>
                    </div>

                    <!-- The Table (One2many Field) -->
                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <!-- Only show templates marked as commitments -->
                            <field name="sign_template_id" domain="[('is_commitment', '=', True)]" options="{'no_create': True}"/>
                            <field name="is_required" widget="boolean_toggle"/>
                            <field name="sign_request_id" readonly="1" string="Generated PDF"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
