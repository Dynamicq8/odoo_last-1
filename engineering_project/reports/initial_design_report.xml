<odoo>
    <record id="action_report_initial_design_form" model="ir.actions.report">
        <field name="name">نموذج تفاصيل المشروع</field>
        <field name="model">project.project</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">engineering_project.report_initial_design_template</field>
        <field name="report_file">engineering_project.report_initial_design_template</field>
        <field name="print_report_name">'Project Form - %s' % (object.name)</field>
        <field name="binding_model_id" ref="project.model_project_project"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_initial_design_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="direction: rtl; text-align: right; font-family: 'DejaVu Sans', sans-serif; border: 1px solid black; padding: 20px;">
                        
                        <div class="text-center mb-4">
                            <h2 style="text-decoration: underline;">نموذج مشاريع مكتب دينامك ديزاين</h2>
                        </div>

                        <!-- Top Info Table -->
                        <table class="table table-bordered" style="width: 100%; border: 2px solid black;">
                            <tr>
                                <td style="width: 50%;"><strong>اسم المالك: </strong> <span t-field="doc.partner_id.name"/></td>
                                <td style="width: 50%;"><strong>رقم التلفون: </strong> <span t-field="doc.partner_id.phone"/></td>
                            </tr>
                        </table>

                        <h4 class="mt-3">بيانات القسيمة:</h4>
                        <table class="table table-bordered" style="width: 100%; border: 2px solid black;">
                            <tr>
                                <td><strong>المنطقة: </strong> <span t-field="doc.region"/></td>
                                <td><strong>القطعة: </strong> <span t-field="doc.block_no"/></td>
                                <td><strong>القسيمة: </strong> <span t-field="doc.plot_no"/></td>
                                <td><strong>المساحة: </strong> <span t-field="doc.area"/></td>
                            </tr>
                        </table>

                        <h4 class="mt-4">تفاصيل مكونات المشروع:</h4>
                        
                        <!-- The Boxes matching your photo -->
                        <div style="border: 2px solid black; min-height: 100px; margin-bottom: 10px; padding: 10px;">
                            <strong>أولاً السرداب:</strong><br/>
                            <span t-field="doc.floor_basement"/>
                        </div>

                        <div style="border: 2px solid black; min-height: 120px; margin-bottom: 10px; padding: 10px;">
                            <strong>ثانياً الدور الأرضي:</strong><br/>
                            <span t-field="doc.floor_ground"/>
                        </div>

                        <div style="border: 2px solid black; min-height: 120px; margin-bottom: 10px; padding: 10px;">
                            <strong>الدور الأول:</strong><br/>
                            <span t-field="doc.floor_first"/>
                        </div>

                        <div style="border: 2px solid black; min-height: 120px; margin-bottom: 10px; padding: 10px;">
                            <strong>الدور الثاني:</strong><br/>
                            <span t-field="doc.floor_second"/>
                        </div>

                        <div style="border: 2px solid black; min-height: 100px; margin-bottom: 10px; padding: 10px;">
                            <strong>الدور السطح:</strong><br/>
                            <span t-field="doc.floor_roof"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
