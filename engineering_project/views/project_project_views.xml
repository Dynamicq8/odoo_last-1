<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================= -->
    <!--  1. MAIN PROJECT FORM (TEAM & BUTTONS)         -->
    <!-- ============================================= -->
    <record id="edit_project_form_engineering" model="ir.ui.view">
        <field name="name">project.project.form.engineering</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="action_start_workflow"
                        string="بدء سير العمل (Start Workflow)"
                        type="object"
                        class="btn-primary"
                        invisible="workflow_started == True or id == False"
                        help="Creates all tasks for this project's workflow."/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sale_order_id" readonly="1"/>

                <field name="workflow_started" invisible="1"/>

                <group string="فريق العمل (Project Team)">
                    <group>
                        <field name="architect_id"/>
                        <field name="structural_id"/>
                        <field name="electrical_id"/>
                        <field name="draftsman_id"/>
                    </group>
                    <group>
                        <field name="secretary_id"/>
                        <field name="accountant_id"/>
                        <field name="facade_draftsman_id"/>
                        <field name="muni_draftsman_id"/>
                    </group>
                </group>

                <group string="بيانات الموقع (Site Details)">
                    <group>
                        <field name="building_type"/>
                        <field name="service_type"/>
                        <field name="governorate_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="region_id"
                               domain="[('governorate_id', '=', governorate_id)]"
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="area"/>
                    </group>
                    <group>
                        <field name="plot_no"/>
                        <field name="block_no"/>
                        <field name="street_no"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ====================================================== -->
    <!--  2. TASK FORM (EDITED WITH NEW TABS)                   -->
    <!-- ====================================================== -->
    <record id="view_task_form2_engineering_extended" model="ir.ui.view">
        <field name="name">project.task.form.engineering.extended</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <xpath expr="//header" position="inside">
                <button name="%(engineering_project.action_report_initial_design_form)d"
                        string="طباعة نموذج المشروع (Print PDF)" type="action" class="btn-primary"
                        invisible="is_disabled"/>
                <button name="action_send_task_form_whatsapp"
                        string="إرسال واتساب (WhatsApp)" type="object" class="btn-success" icon="fa-whatsapp"
                        invisible="is_disabled"/>
                <!-- NEW: Send PDF of نموذج مكونات المشروع via WhatsApp -->
                <button name="action_send_project_form_pdf_whatsapp"
                        string="إرسال نموذج المكونات واتساب" type="object" class="btn-success" icon="fa-whatsapp"
                        invisible="is_disabled or workflow_step not in ['rn_1_1','nrn_1_1','ra_1_3','nra_1_3']"/>
                <button name="action_view_parent_project"
                        string="الذهاب للمشروع (Go to Project)" type="object" icon="fa-briefcase"/>
            </xpath>

            <xpath expr="//sheet/div[hasclass('oe_title')]" position="before">
                <field name="is_disabled" invisible="1"/>
                <field name="is_paperwork_task" invisible="1"/>
                <field name="is_engineering_task" invisible="1"/>

                <!-- Hidden field to carry workflow_step for use in invisible expressions -->
                <field name="workflow_step" invisible="1"/>

                <div class="alert alert-danger text-center" role="alert" invisible="not is_disabled" style="margin-bottom: 10px;">
                    <i class="fa fa-lock fa-2x"/> <br/>
                    <strong>هذه المهمة مقفلة (Disabled)!</strong><br/>
                    يرجى الانتهاء من المهام السابقة في سير العمل حتى يتم تفعيل هذه المهمة تلقائياً.
                </div>
            </xpath>

            <xpath expr="//notebook" position="inside">

                <!--
                    تبويب نموذج مكونات المشروع
                -->
                <page string="نموذج مكونات المشروع" name="project_details_form"
                      invisible="
                          not is_engineering_task
                          or workflow_step not in [
                              'rn_1_1',
                              'nrn_1_1',
                              'ra_1_3',
                              'nra_1_3',
                          ]
                      ">

                    <div class="mb-3 mt-2">
                        <button name="action_load_default_phases" type="object"
                                string="تحميل المراحل الافتراضية (Load Defaults)"
                                class="btn-secondary" icon="fa-list-ol"
                                invisible="phase_ids != [] or is_disabled"/>
                        <span class="text-muted ms-3">
                            <i class="fa fa-info-circle"/> للمشاريع الاستثمارية/التجارية، يمكنك إضافة أدوار ومراحل جديدة يدوياً من الأسفل.
                        </span>
                    </div>

                    <!--
                        FIX: Use 'text' widget on the 'name' field so multi-line input
                        is preserved and does not collapse on blur. Also set
                        optional="show" on columns so they always display.
                    -->
                    <field name="phase_ids" context="{'default_task_id': active_id}" readonly="is_disabled">
                        <tree editable="bottom"
                              decoration-success="is_completed==True"
                              decoration-muted="is_completed==False">
                            <field name="sequence" widget="handle"/>
                            <field name="floor_category"
                                   placeholder="مثال: الدور الثالث"
                                   string="الدور"/>
                            <field name="name"
       string="المرحلة"
       widget="text" 
       style="white-space: pre-wrap !important;" 
       placeholder="مثال: مرحلة أعمدة الدور الثالث"/>
                            <field name="is_completed" widget="boolean_toggle" string="تم"/>
                        </tree>
                    </field>

                    <!-- Button to send this tab's PDF via WhatsApp (inside the tab) -->
                    <div class="mt-3" invisible="is_disabled">
                        <button name="action_send_project_form_pdf_whatsapp"
                                type="object"
                                string="إرسال نموذج المكونات عبر واتساب"
                                class="btn-success"
                                icon="fa-whatsapp"/>
                    </div>
                </page>

                <!--
                    تبويب رسومات كروكي
                -->
                <page string="رسومات كروكي (Sketches)" name="sketches"
                      invisible="
                          not is_engineering_task
                          or workflow_step not in [
                              'rn_1_1',
                              'nrn_1_1',
                              'ra_1_3',
                              'nra_1_3'
                          ]
                      ">

                    <field name="sketch_ids" nolabel="1" readonly="is_disabled">
                        <tree>
                            <field name="name"/>
                            <field name="create_date" string="تاريخ الإنشاء"/>
                            <field name="created_by_id"/>
                            <button name="action_open_sketch_editor"
                                    type="object"
                                    icon="fa-pencil"
                                    string="تعديل"
                                    help="Open Sketch Editor"/>
                        </tree>

                        <form>
                            <sheet>
                                <group>
                                    <field name="name"/>
                                    <field name="created_by_id" readonly="1"/>
                                    <field name="create_date" readonly="1"/>
                                </group>

                                <separator string="Sketch Pad"/>
                                <field name="sketch_image"
                                       widget="sketch_pad_editor"
                                       style="width: 100%; height: 500px;"/>
                            </sheet>
                        </form>
                    </field>

                    <button name="action_create_new_sketch"
                            type="object"
                            string="إضافة رسم كروكي جديد"
                            class="oe_highlight"
                            icon="fa-plus-circle"
                            invisible="is_disabled"/>

                    <field name="sketch_count" invisible="1"/>

                </page>

                <!--
                    تبويب المرفقات
                -->
                <page string="مرفقات" name="proofs_attachments">
                    <p class="text-muted">
                        قم برفع صور، ملفات PDF، أو أي مستندات أخرى كإثباتات للمهمة. (اضغط على إضافة سطر للرفع)
                    </p>
                    <field name="proof_attachment_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="name" string="اسم الملف"/>
                            <field name="mimetype" readonly="1" optional="hide"/>
                            <field name="create_date" readonly="1"/>
                            <field name="datas" filename="name" widget="binary" string="رفع الملف (Upload)"/>
                            <button name="action_send_attachment_whatsapp"
                                    type="object"
                                    string="إرسال واتساب"
                                    icon="fa-whatsapp"
                                    class="btn-success"/>
                        </tree>
                    </field>
                </page>

            </xpath>
        </field>
    </record>

    <!-- ACTION TO OPEN SKETCH EDITOR FORM -->
    <record id="action_project_task_sketch_form" model="ir.actions.act_window">
        <field name="name">Sketch Editor</field>
        <field name="res_model">project.task.sketch</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ====================================================== -->
    <!--  3. TASK KANBAN (NO CHANGES)                           -->
    <!-- ====================================================== -->
    <record id="view_task_kanban_engineering" model="ir.ui.view">
        <field name="name">project.task.kanban.engineering</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">

            <xpath expr="//templates" position="before">
                <field name="is_disabled" invisible="1"/>
            </xpath>

            <xpath expr="//t[@t-name='kanban-box']/div" position="attributes">
                <attribute name="t-attf-style">opacity: #{record.is_disabled.raw_value ? '0.4' : '1.0'}; pointer-events: #{record.is_disabled.raw_value ? 'none' : 'auto'};</attribute>
            </xpath>

            <xpath expr="//strong[hasclass('o_kanban_record_title')]" position="after">
                <div t-if="record.is_disabled.raw_value" class="text-danger mt-1" style="font-weight: bold; font-size: 11px;">
                    <i class="fa fa-lock"/> مقفلة (بانتظار المهام السابقة)
                </div>
            </xpath>

        </field>
    </record>
</odoo>