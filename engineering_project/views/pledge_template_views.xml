<odoo>
    <!-- Form View -->
    <record id="view_pledge_template_form" model="ir.ui.view">
        <field name="name">engineering.pledge.template.form</field>
        <field name="model">engineering.pledge.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="مثال: تعهد عدم التأجير والتجزئة"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="building_type"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="نص التعهد (Pledge Text)">
                            <!-- Hint for the user -->
                            <div class="alert alert-info" role="alert">
                                <strong>الأكواد المتاحة للاستخدام (Placeholders):</strong><br/>
                                اسم المالك: <code>{{partner_name}}</code> | 
                                المحافظة: <code>{{governorate}}</code> | 
                                المنطقة: <code>{{region}}</code> | 
                                القطعة: <code>{{block_no}}</code> | 
                                القسيمة: <code>{{plot_no}}</code> | 
                                التاريخ: <code>{{date}}</code>
                            </div>
                            <field name="body_html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_pledge_template_tree" model="ir.ui.view">
        <field name="name">engineering.pledge.template.tree</field>
        <field name="model">engineering.pledge.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="building_type"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pledge_templates" model="ir.actions.act_window">
        <field name="name">قوالب التعهدات (Pledges)</field>
        <field name="res_model">engineering.pledge.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item (We will put it under Configuration in the Project App) -->
    <menuitem id="menu_project_pledge_templates"
              name="قوالب التعهدات"
              parent="project.menu_project_config"
              action="action_pledge_templates"
              sequence="50"/>
</odoo>
