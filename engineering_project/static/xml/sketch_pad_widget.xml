<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="engineering_project.SketchPadWidget">
        <div class="o_sketch_pad_wrapper border bg-light">
            <!-- Toolbar -->
            <div class="d-flex align-items-center p-2 border-bottom" style="gap: 15px;">
                <!-- Tools -->
                <button class="btn btn-secondary btn-sm" t-on-click="setPenMode" title="Pen">
                    <i class="fa fa-pencil"/> Pen
                </button>
                <button class="btn btn-secondary btn-sm" t-on-click="setEraserMode" title="Eraser">
                    <i class="fa fa-eraser"/> Eraser
                </button>

                <!-- Color Picker (Added t-ref) -->
                <div class="d-flex align-items-center">
                    <label class="me-2">Color:</label>
                    <input type="color" t-ref="colorPicker" class="form-control form-control-color" value="#000000" t-on-input="changeColor"/>
                </div>

                <!-- Size Picker (Added t-ref) -->
                <div class="d-flex align-items-center">
                    <label class="me-2">Size:</label>
                    <input type="range" t-ref="sizePicker" class="form-range" min="1" max="50" value="5" t-on-input="changeBrushSize"/>
                </div>

                <!-- Actions -->
                <div class="ms-auto d-flex" style="gap: 10px;">
                    <button class="btn btn-danger btn-sm" t-on-click="clearCanvas" title="Clear All">
                        <i class="fa fa-trash"/> Clear
                    </button>
                    <button class="btn btn-primary btn-sm" t-on-click="saveCanvas" title="Save Sketch to Odoo">
                        <i class="fa fa-save"/> Save
                    </button>
                    <button class="btn btn-success btn-sm" t-on-click="downloadCanvas" title="Download as PNG">
                        <i class="fa fa-download"/> Download
                    </button>
                </div>
            </div>

            <!-- Canvas Area -->
            <div class="o_sketch_pad_canvas_container p-1">
                <canvas t-ref="canvas" class="border" style="box-shadow: 0 0 5px rgba(0,0,0,0.1);"/>
            </div>
        </div>
    </t>

</templates>