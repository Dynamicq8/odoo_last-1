<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="engineering_project.SketchPadWidget" owl="1">
        <div class="o_field_sketch_pad_container" t-att-class="{ 'o_field_empty': !props.value, 'o_field_widget': true }">
            <div class="sketch-controls bg-light p-2 mb-2 d-flex flex-wrap align-items-center justify-content-center">
                <div class="d-flex align-items-center me-3 mb-2 mb-md-0">
                    <button type="button" class="btn btn-outline-primary btn-sm me-2" t-att-class="{ 'active': currentMode.mode === 'pen' }" t-on-click="setPenMode">
                        <i class="fa fa-pencil"/> Pen
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm me-2" t-att-class="{ 'active': currentMode.mode === 'eraser' }" t-on-click="setEraserMode">
                        <i class="fa fa-eraser"/> Eraser
                    </button>
                    <input type="color" class="form-control form-control-color me-2" t-ref="colorPicker" value="#000000" t-on-change="changeColor"/>
                    <input type="range" class="form-range" min="1" max="20" value="5" t-ref="sizePicker" t-on-input="changeBrushSize" style="width: 80px;"/>
                    <span class="ms-2">Size</span>
                </div>

                <div class="d-flex align-items-center me-3 mb-2 mb-md-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm me-2" t-att-class="{ 'active': currentMode.mode === 'text' || currentMode.mode === 'text_edit' }" t-on-click="setTextMode">
                        <i class="fa fa-font"/> Text
                    </button>
                    <input type="text" class="form-control form-control-sm me-2" t-ref="textInput" placeholder="Type text here..." style="width: 150px;"/>
                </div>

                <div class="d-flex align-items-center">
                    <button type="button" class="btn btn-outline-warning btn-sm me-2" t-on-click="clearCanvas">
                        <i class="fa fa-trash"/> Clear
                    </button>
                    <button type="button" class="btn btn-success btn-sm me-2" t-on-click="saveCanvas">
                        <i class="fa fa-save"/> Save
                    </button>
                    <button type="button" class="btn btn-info btn-sm" t-on-click="downloadCanvas">
                        <i class="fa fa-download"/> Download
                    </button>
                </div>
            </div>
            <canvas t-ref="canvas" class="border border-dark bg-white"/>
        </div>
    </t>

</templates>