<odoo>
    <record id="sale_order_view_form_engineering" model="ir.ui.view">
        <field name="name">sale.order.form.engineering</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <!-- Project Details Section -->
                <div class="oe_title">
                    <h3><label for="building_type" string="بيانات المشروع (Project Details)"/></h3>
                </div>

                <group name="project_details_section_main">
                    <group name="project_details_column_one">
                        <field name="building_type"/>
                        <field name="service_type"/>
                    </group>
                    <group name="project_details_column_two_spacer">
                        <!-- Empty group for spacing/column alignment -->
                    </group>
                </group>

                <!-- Location Details Section -->
                <div class="oe_title">
                    <h3><label for="area" string="تفاصيل الموقع (Location Details)"/></h3>
                </div>

                <!-- NEW: Separate groups for pairs of fields to maximize space -->
                <group name="location_details_row_one">
                    <group name="location_details_col_1">
                        <field name="area"/>
                        <field name="block_no"/>
                    </group>
                    <group name="location_details_col_2_spacer">
                        <!-- Empty group to push content left/right and ensure space -->
                    </group>
                </group>

                <!-- Ensure Street and Plot No. get their own full horizontal space -->
                <group name="location_details_row_two">
                    <group name="location_details_col_3">
                        <field name="street_no"/>
                        <field name="plot_no"/>
                    </group>
                    <group name="location_details_col_4_spacer">
                        <!-- Empty group for spacing/column alignment -->
                    </group>
                </group>

                <!-- You can also add a horizontal rule for extra visual separation if needed: -->
                <!-- <separator/> -->

            </xpath>
        </field>
    </record>
</odoo>
