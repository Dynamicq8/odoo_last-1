<odoo>
    <!-- Tree View for Project Document Link -->
    <record id="project_document_pledge_view_tree" model="ir.ui.view">
        <field name="name">project.document.pledge.tree</field>
        <field name="model">project.document.pledge</field>
        <field name="arch" type="xml">
            <tree string="Project Documents">
                <field name="name"/>
                <field name="document_template_id"/>
                <field name="is_required" widget="toggle_button"/>
                <field name="generated_sign_request_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View (basic) -->
    <record id="project_document_pledge_view_form" model="ir.ui.view">
        <field name="name">project.document.pledge.form</field>
        <field name="model">project.document.pledge</field>
        <field name="arch" type="xml">
            <form string="Project Document">
                <sheet>
                    <group>
                        <field name="document_template_id"/>
                        <field name="is_required"/>
                        <field name="generated_sign_request_id" readonly="1"/>
                        <field name="task_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
